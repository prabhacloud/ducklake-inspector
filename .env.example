# Path to a local DuckLake metadata database (.db file created by `ATTACH 'ducklake:lake_meta.db' ...`)
# The data path is read from the catalog itself — no need to supply it.
DUCKLAKE_METADATA_PATH=/tmp/ducklake-probe/lake_meta.db

# Optional — enables the AI executive summary on /audit. Set at least one key.
# If both are set, LLM_PROVIDER selects between them (default: anthropic).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=anthropic          # or 'openai'
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
